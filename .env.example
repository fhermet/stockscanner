# Data Provider
# Par défaut, l'app utilise les données mockées (local dataset).
# Si YAHOO_ENABLED=true, elle interroge Yahoo Finance (gratuit, sans clé API).
# YAHOO_ENABLED=true

# URL publique du site (utilisée pour sitemap, robots.txt, canonical URLs, OG tags)
# À configurer dans Vercel avec votre domaine réel.
# NEXT_PUBLIC_SITE_URL=https://stockscanner.app

# Cache TTL (optionnel, en millisecondes)
# CACHE_STOCKS_TTL=3600000
# CACHE_STOCK_TTL=900000
