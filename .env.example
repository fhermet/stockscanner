# Data Provider
# Si FMP_API_KEY est defini, l'app utilise Financial Modeling Prep.
# Sinon, elle utilise les donnees mockees.
# Plan gratuit : https://financialmodelingprep.com/developer/docs/
# FMP_API_KEY=your_api_key_here

# Cache TTL (optionnel, en millisecondes)
# CACHE_STOCKS_TTL=3600000
# CACHE_STOCK_TTL=900000
